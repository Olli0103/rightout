  "uiHints": {
    "braveApiKey": {
      "label": "Brave Search API key",
      "help": "Used only after an assisted scan-specific allow-once approval or validation of a matching finite campaign grant. Configure as an OpenClaw SecretRef.",
      "sensitive": true
    },
    "profiles.*.payload": {
      "label": "Private subject profile",
      "help": "JSON profile and recorded consent. Configure only as an OpenClaw SecretRef; never as plaintext.",
      "sensitive": true
    },
    "smtpTransport.host": {
      "label": "SMTP host",
      "help": "Fail-closed allowlist: Gmail, Yahoo, iCloud, or Fastmail SMTP only."
    },
    "smtpTransport.username": {
      "label": "SMTP username",
      "help": "Configure as an OpenClaw SecretRef.",
      "sensitive": true
    },
    "smtpTransport.password": {
      "label": "SMTP app password",
      "help": "Use a provider-specific app password through an OpenClaw SecretRef.",
      "sensitive": true
    },
    "smtpTransport.oauthAccessToken": {
      "label": "SMTP OAuth2 access token",
      "help": "Short-lived provider access token. Configure only through an OpenClaw SecretRef; mixed password and OAuth credentials are rejected.",
      "sensitive": true
    },
    "smtpTransport.oauthExpiresAt": {
      "label": "SMTP OAuth2 token expiry",
      "help": "ISO timestamp between 1 minute and 24 hours in the future. Expired or unusually long-lived bearer tokens fail closed."
    },
    "smtpTransport.fromAddress": {
      "label": "Removal sender address",
      "help": "Must equal the subject profile contact email. Configure as an OpenClaw SecretRef.",
      "sensitive": true
    },
    "imapTransport.host": {
      "label": "IMAP host",
      "help": "Fail-closed allowlist: Gmail IMAP over port 993 only, with receiver-added mx.google.com authentication results."
    },
    "imapTransport.username": {
      "label": "IMAP username",
      "help": "Configure as an OpenClaw SecretRef.",
      "sensitive": true
    },
    "imapTransport.password": {
      "label": "IMAP app password",
      "help": "Configure as an OpenClaw SecretRef.",
      "sensitive": true
    },
    "imapTransport.oauthAccessToken": {
      "label": "IMAP OAuth2 access token",
      "help": "Short-lived Gmail access token. Configure only through an OpenClaw SecretRef; mixed password and OAuth credentials are rejected.",
      "sensitive": true
    },
    "imapTransport.oauthExpiresAt": {
      "label": "IMAP OAuth2 token expiry",
      "help": "ISO timestamp between 1 minute and 24 hours in the future. Expired or unusually long-lived bearer tokens fail closed."
    },
    "imapTransport.address": {
      "label": "Verification mailbox address",
      "help": "Must equal the subject profile contact email. Configure as an OpenClaw SecretRef.",
      "sensitive": true
    },
    "operatorAttestations": {
      "label": "Live-scan attestations",
      "help": "Exact profile/broker scope plus pinned Brave terms and customer responsibilities.",
      "advanced": true
    },
    "removalAttestations": {
      "label": "Removal-write attestations",
      "help": "Separate exact scope for subject consent, SMTP authority, minimum disclosure, and removal policy.",
      "advanced": true
    },
    "verificationAttestations": {
      "label": "Inbox-verification attestations",
      "help": "Separate exact scope for subject consent, read-only inbox access, confirmation-link opening, and verification policy. Bind IMAP with imapTransportDigest or one existing_logged_in_cdp profile with the browserProfileDigest reported by rightout_setup.",
      "advanced": true
    },
    "controllerReplyAttestations": {
      "label": "Controller-reply attestations",
      "help": "Separate exact scope for read-only mailbox access and authenticated, thread-bound controller reply candidates. Candidates never become outcomes without a new native human approval.",
      "advanced": true
    },
    "formAttestations": {
      "label": "Browser-form attestations",
      "help": "Separate exact scope for subject consent, minimum disclosure, configured OpenClaw browser-backend form writes, and the form policy.",
      "advanced": true
    },
    "stateEncryptionKey": {
      "label": "RightOut state encryption key",
      "help": "At least 32 random characters. Encrypts all durable plugin state at rest; configure only as an OpenClaw SecretRef.",
      "sensitive": true
    },
    "previousStateEncryptionKeys.*": {
      "label": "Previous RightOut state key",
      "help": "Temporary SecretRef used only during an approved state-key rotation. Remove after rotation succeeds.",
      "sensitive": true,
      "advanced": true
    },
    "stateRetentionDays": {
      "label": "Encrypted case retention",
      "help": "Days since the last case update before encrypted subject cases expire automatically (30-730; default 365).",
      "advanced": true
    },
    "directScanAttestations": {
      "label": "Direct-rescan attestations",
      "help": "Separate exact scope for subject consent, publisher access, publisher terms review, and direct-rescan policy.",
      "advanced": true
    },
    "browserControlBaseUrl": {
      "label": "OpenClaw browser control URL",
      "help": "Optional loopback-only standalone OpenClaw browser-control HTTP URL for unsandboxed/host-profile lanes. Production sandboxed agents may use toolContext.browser.sandboxBridgeUrl instead. Host mode requires OPENCLAW_EAGER_BROWSER_CONTROL_SERVER=1 and uses gateway.port + 2.",
      "advanced": true
    },
    "browserProfile": {
      "label": "RightOut browser profile",
      "help": "Optional OpenClaw browser profile name. Use a managed profile, a remote CDP cloud-browser profile, or an attach-only raw-CDP profile signed into webmail.",
      "advanced": true
    },
    "browserBackendMode": {
      "label": "RightOut browser backend mode",
      "help": "Classify the backend as OpenClaw-managed (production sandbox bridge or standalone host transport), remote/cloud CDP, or existing logged-in CDP. browser_control_transport reports the actual transport; webmail is enabled only for the last backend.",
      "advanced": true
    },
    "remoteCloudBrowserProfile": {
      "label": "Remote cloud fallback profile",
      "help": "Optional distinct OpenClaw remote-CDP browser profile used once after a blocked primary browser route.",
      "advanced": true
    },
    "browserControlToken": {
      "label": "Browser control API token",
      "help": "Required Gateway bearer token whenever browserControlBaseUrl enables the standalone loopback browser API. Configure only as an OpenClaw SecretRef; the sandbox bridge does not need this field.",
      "sensitive": true,
      "advanced": true
    },
    "publisherAutomationPermissions": {
      "label": "Provider automation permissions",
      "help": "Fail-closed per-broker records for current written provider authorization, exact allowed effects, and allowed browser backend classes. User consent or a RightOut attestation alone is never sufficient.",
      "advanced": true
    },
    "customTargetRecipePacks": {
      "label": "Custom-target signed recipe packs",
      "help": "External Ed25519-signed recipe packs for encrypted custom-target handles. Raw target facts never appear in public tools.",
      "advanced": true
    },
    "customTargetTrustedKeys": {
      "label": "Custom-target trusted public keys",
      "help": "Allowlisted Ed25519 public keys used only to verify external custom-target recipe packs.",
      "advanced": true
    },
    "customTargetPermissions": {
      "label": "Custom-target permissions",
      "help": "Current written authorization bound to one opaque custom-target handle, exact recipe digest, official-domain digest, lifetime, and effect.",
      "advanced": true
    },
    "effectivenessCanaries": {
      "label": "Authorized effectiveness canaries",
      "help": "Versioned out-of-band evidence for reviewed identity outcomes, delivery, provider outcomes, direct absence, reappearance, and human handoff. Each fact requires opaque proof plus authorization and deployment digests; technical capability never counts as effectiveness.",
      "advanced": true
    },
    "teamAccess": {
      "label": "Family and team access",
      "help": "Session-bound owner, manager, and viewer roles with exact authorized profile scopes. Generate one-way bindings with rightout_team_session_binding.",
      "advanced": true
    }
  },

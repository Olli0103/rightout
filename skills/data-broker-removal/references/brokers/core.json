        "native_openclaw_plugin_approval",
        "brave_search_api"
      ],
      "approval_gate": "live_scan",
      "human_only": false,
      "last_verified": "2026-07-11",
      "freshness_days": 90,
      "source_license": "official-facts-only-no-content-copy",
      "sources": [
        {
          "url": "https://www.truepeoplesearch.com/",
          "title": "TruePeopleSearch official site",
          "publisher": "TruePeopleSearch",
          "license_scope": "official_identity_url_and_facts_only",
          "last_verified": "2026-07-11"
        },
        {
          "url": "https://www.truepeoplesearch.com/removal",
          "title": "TruePeopleSearch official removal entry point",
          "publisher": "TruePeopleSearch",
          "license_scope": "official_url_fact_only",
          "last_verified": "2026-07-11"
        }
      ],
      "scan": {
        "supported": true,
        "strategy": "brave_site_query_then_same_domain_verify",
        "query_fields": [
          "full_name",
          "city",
          "region"
        ],
        "search_provider_host": "api.search.brave.com",
        "candidate_path_pattern": "^/find/person/(?:[A-Za-z0-9%._~-]+/){0,5}[A-Za-z0-9%._~-]+/?$",
        "max_candidates": 3,
        "not_found_policy": "never_from_index_absence"
      },
      "notes": "Read-only discovery only. The approved plugin sends minimum name and location fields to Brave Search, then verifies same-domain candidate pages. CAPTCHA, removal, email, and submissions are out of scope."
    },
